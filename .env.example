# ============================================================
# zy-news 爬虫系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值，启动程序时 config.py 会自动加载
# ============================================================

# ============================================================
# LLM 大语言模型配置 (供 ScrapeGraphAI 使用，用于智能提取新闻结构化数据)
# ============================================================

# LLM 提供商: openai_compatible (vLLM 本地部署)
LLM_PROVIDER=openai_compatible

# ---------------- vLLM 配置 ----------------
# vLLM 服务地址 (需加 /v1 后缀)
OPENAI_BASE_URL=http://localhost:8000/v1
# vLLM 中部署的模型名称
OPENAI_MODEL_NAME=/data/model/qwen3_6_27B_FP8/Qwen/Qwen3_6-27B-FP8
# API Key (vLLM 本地部署不需要)
OPENAI_API_KEY=your-api-key-here
# 温度 (0-1)，越低越稳定，提取结构化数据建议设为 0
OPENAI_TEMPERATURE=0.0
# 最大输出 tokens (Qwen3 思考模型需要大值，思考+输出共用此配额)
OPENAI_MAX_TOKENS=16384
# 推理深度 (low | medium | high)，high=最深度思考，适合复杂结构化提取
REASONING_EFFORT=high

# ---------------- ScrapeGraphAI 功能开关 ----------------
# 是否启用深度搜索模式 (对页面做更深度的内容提取，但会增加 LLM 调用量)
USE_DEEP_SCRAPER=true

# ============================================================
# PostgreSQL 数据库配置 (使用连接池管理连接)
# ============================================================

# 数据库服务器地址
DB_HOST=localhost
# 数据库端口 (PostgreSQL 默认 5432)
DB_PORT=5432
# 数据库名称 (会自动创建表，库需提前创建)
DB_NAME=zy_news
# 数据库用户名
DB_USER=postgres
# 数据库密码
DB_PASSWORD=postgres

# ---------------- 连接池参数 ----------------
# 连接池最小保持连接数 (即使空闲也保持这么多连接在线)
DB_POOL_MIN_SIZE=2
# 连接池最大连接数 (控制并发，避免打满数据库)
DB_POOL_MAX_SIZE=10
# 连接最大空闲时间 (秒)，超过后会被回收
DB_POOL_MAX_IDLE=300
# 连接最大生命周期 (秒)，超过后会重建连接避免 stale 连接
DB_POOL_MAX_LIFETIME=3600

# ============================================================
# 爬虫行为配置 (控制爬取频率和隐身策略，模拟真人行为降低被封风险)
# ============================================================

# ---------------- 浏览器基础配置 ----------------
# 无头模式: false = 显示浏览器窗口(便于调试观察)，true = 不显示窗口(服务部署用)
CRAWLER_HEADLESS=false
# 隐匿模式: 是否启用 stealth 插件，清除自动化特征，建议开启
CRAWLER_STEALTH=true
# 代理地址: 需要代理时填写，格式: http://user:pass@host:port，留空不使用
CRAWLER_PROXY=
# 页面加载超时时间 (毫秒)，超时则放弃当前页面
CRAWLER_TIMEOUT=30000

# ---------------- 人类行为模拟 - 随机延迟 ----------------
# 页面跳转之间最小延迟 (秒)
HUMAN_DELAY_MIN=3.0
# 页面跳转之间最大延迟 (秒)
# 实际延迟在 [min, max] 之间随机，避免固定间隔被识别
HUMAN_DELAY_MAX=8.0
# 不同关键词搜索之间最小延迟 (秒)，关键词切换建议间隔更长
KEYWORD_DELAY_MIN=10.0
# 不同关键词搜索之间最大延迟 (秒)
KEYWORD_DELAY_MAX=20.0

# ---------------- 人类行为模拟 - 交互动作 ----------------
# 是否模拟鼠标随机移动，更像真人操作
HUMAN_MOUSE_MOVE=true
# 是否模拟随机滚动页面，触加载加载并模拟阅读行为
HUMAN_RANDOM_SCROLL=true

# ---------------- 爬取频率控制 ----------------
# 最大并发爬取数 (控制同时爬几个页面，不宜过高)
MAX_CONCURRENT=2
# 每个关键词最多爬取多少页
MAX_PAGES_PER_KEYWORD=2
# 是否只抓取当天新闻: true = 仅当天，false = 不限日期
TODAY_ONLY=true
# 请求失败最大重试次数
MAX_RETRIES=3
# 重试基础延迟 (秒)，每次重试会递增
RETRY_DELAY=3.0

# ============================================================
# 日志配置 (使用 loguru 日志框架)
# ============================================================

# 日志级别: DEBUG | INFO | WARNING | ERROR
# DEBUG 输出详细调试信息，生产环境建议 INFO
LOG_LEVEL=DEBUG
# 日志切割大小，达到这个大小会自动轮转
LOG_ROTATION=10 MB
# 日志保留天数，超过自动清理
LOG_RETENTION=7 days
